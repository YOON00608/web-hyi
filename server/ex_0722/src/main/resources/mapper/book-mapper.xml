<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
<mapper namespace="com.korea.ex_0722.dao.BookDAO">
	<!-- 전체 도서 검색 -->
    <select id="findAll" resultType="BookVO">
    	SELECT 
	    	id,
		    title,
		    author,
		    category,
		    price,
		    stock
		FROM books
    </select>
    
    <!-- id로 도서 검색 -->
    <select id="findBook" resultType="BookVO">
        SELECT id, title, author FROM books WHERE id = #{id}
    </select>
	
	<!-- 도서 등록 -->
	
	<insert id="insertBook">
		insert into books(title,author,category,price,stock)
		VALUES(#{title},#{author},#{category},#{price},#{stock}) 
	</insert>
	
	
	
	
</mapper>